# Ключи для бота Вайб
# Скопируйте в .env и подставьте свои значения

# Telegram Bot Token — получите у @BotFather в Telegram
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key — для парсинга дат и слотов через LLM (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
